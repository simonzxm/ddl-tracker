# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ddl_tracker

# Redis
REDIS_URL=redis://localhost:6379/0

# Session
SESSION_SECRET_KEY=your-secret-key-change-in-production
SESSION_EXPIRE_SECONDS=86400

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=DDL Tracker <noreply@example.com>

# App
APP_ENV=development
DEBUG=true
ALLOWED_EMAIL_DOMAINS=smail.nju.edu.cn,nju.edu.cn

# Karma thresholds
KARMA_VERIFIED_THRESHOLD=50
KARMA_HIDDEN_THRESHOLD=-10
KARMA_UPVOTE_GAIN=5
KARMA_DOWNVOTE_LOSS=2
