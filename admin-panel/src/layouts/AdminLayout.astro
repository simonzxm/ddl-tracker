---
import '../styles/global.css'

interface Props {
  title: string;
  currentPage?: string;
}

const { title, currentPage = '' } = Astro.props;

const navItems = [
  { href: '/', label: '大盘', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { href: '/tasks', label: '任务审核', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { href: '/users', label: '用户管理', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z' },
  { href: '/courses', label: '课程管理', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - DDL Tracker 管理</title>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <div class="flex">
      <!-- Sidebar -->
      <aside class="w-64 bg-slate-800 min-h-screen fixed left-0 top-0">
        <div class="p-6">
          <h1 class="text-xl font-bold text-white">DDL Tracker</h1>
          <p class="text-slate-400 text-sm">管理面板</p>
        </div>
        <nav class="mt-4">
          {navItems.map(item => (
            <a 
              href={item.href}
              class:list={[
                'flex items-center gap-3 px-6 py-3 text-sm transition-colors',
                currentPage === item.href 
                  ? 'bg-slate-700 text-white border-r-4 border-blue-500' 
                  : 'text-slate-300 hover:bg-slate-700 hover:text-white'
              ]}
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
              {item.label}
            </a>
          ))}
        </nav>
      </aside>
      
      <!-- Main content -->
      <main class="ml-64 flex-1 p-8">
        <slot />
      </main>
    </div>
  </body>
</html>
