---
import AdminLayout from '../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<AdminLayout title="课程管理" currentPage="/courses">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">课程管理</h2>
      <p class="text-gray-500 mt-1">管理课程底库</p>
    </div>
    <div class="flex gap-2">
      <input 
        type="text" 
        id="search-input"
        placeholder="搜索课程..." 
        class="px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <button id="export-btn" class="px-4 py-2 bg-purple-500 text-white rounded-lg hover:bg-purple-600">
        导出
      </button>
      <button id="bulk-import-btn" class="px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600">
        批量导入
      </button>
      <button id="add-course-btn" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
        添加课程
      </button>
    </div>
  </div>
  
  <!-- Course Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">ID</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">课号</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">名称</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">教师</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">班号</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">学期</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">校区</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">关注</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">操作</th>
        </tr>
      </thead>
      <tbody id="course-list">
        <tr>
          <td colspan="9" class="text-center py-8 text-gray-500">加载中...</td>
        </tr>
      </tbody>
    </table>
  </div>
</AdminLayout>

<!-- Add/Edit Course Modal -->
<div id="course-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
  <div class="bg-white rounded-xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
    <h3 id="modal-title" class="text-lg font-semibold mb-4">添加课程</h3>
    <form id="course-form" class="space-y-4">
      <input type="hidden" id="course-id" />
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">课程号 *</label>
          <input type="text" id="course-code" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 22000160" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">班号</label>
          <input type="text" id="course-class-number" class="w-full px-3 py-2 border rounded-lg" placeholder="如: 03班" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">课程名称 *</label>
        <input type="text" id="course-name" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 数字逻辑与计算机组成" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">简称</label>
          <input type="text" id="course-abbr" class="w-full px-3 py-2 border rounded-lg" placeholder="如: DLCO" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">授课教师 *</label>
          <input type="text" id="course-teacher" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 杨若瑜" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">学期 *</label>
          <input type="text" id="course-semester" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 2026-Spring" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">校区</label>
          <input type="text" id="course-campus" class="w-full px-3 py-2 border rounded-lg" placeholder="如: 鼓楼校区" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">时间地点</label>
        <textarea id="course-time-location" rows="2" class="w-full px-3 py-2 border rounded-lg" placeholder="如: 周一 1-2节 教学楼A101"></textarea>
      </div>
      <div class="flex gap-2 justify-end">
        <button type="button" id="cancel-btn" class="px-4 py-2 bg-gray-100 rounded-lg">取消</button>
        <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg">保存</button>
      </div>
    </form>
  </div>
</div>

<!-- Bulk Import Modal -->
<div id="bulk-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
  <div class="bg-white rounded-xl p-6 w-full max-w-3xl max-h-[90vh] overflow-y-auto">
    <h3 class="text-lg font-semibold mb-4">批量导入课程</h3>
    
    <div class="mb-4 p-4 bg-blue-50 rounded-lg text-sm text-blue-800">
      <p class="font-medium mb-2">支持的格式：</p>
      <ul class="list-disc list-inside space-y-1">
        <li><strong>CSV 格式</strong>：课号,课程名,简称,教师,学期,班号,校区,时间地点</li>
        <li><strong>JSON 格式</strong>：数组格式，每个对象包含 code, name, name_abbr, teacher, semester, class_number, campus, time_location</li>
      </ul>
      <p class="mt-2 text-blue-600">示例 CSV（简称/班号/校区/时间地点可留空）：</p>
      <code class="block bg-white p-2 rounded mt-1 text-xs">
22000160,数字逻辑与计算机组成,DLCO,杨若瑜,2026-Spring,03班,鼓楼校区,周一 1-2节<br/>
22000161,计算机网络,,张三,2026-Spring,01班,,
      </code>
    </div>
    
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">选择格式</label>
      <div class="flex gap-4">
        <label class="flex items-center gap-2">
          <input type="radio" name="import-format" value="csv" checked class="text-blue-500" />
          <span>CSV</span>
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="import-format" value="json" class="text-blue-500" />
          <span>JSON</span>
        </label>
      </div>
    </div>
    
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">粘贴数据</label>
      <textarea 
        id="bulk-data" 
        rows="10" 
        class="w-full px-3 py-2 border rounded-lg font-mono text-sm"
        placeholder="在此粘贴课程数据..."
      ></textarea>
    </div>
    
    <div class="mb-4">
      <label class="flex items-center gap-2">
        <input type="checkbox" id="skip-duplicates" checked class="text-blue-500" />
        <span class="text-sm text-gray-700">跳过重复课程（课号+教师+学期+班号相同）</span>
      </label>
    </div>
    
    <!-- Import Result -->
    <div id="import-result" class="hidden mb-4 p-4 rounded-lg">
    </div>
    
    <div class="flex gap-2 justify-end">
      <button type="button" id="bulk-cancel-btn" class="px-4 py-2 bg-gray-100 rounded-lg">取消</button>
      <button type="button" id="bulk-preview-btn" class="px-4 py-2 bg-yellow-500 text-white rounded-lg">预览</button>
      <button type="button" id="bulk-submit-btn" class="px-4 py-2 bg-green-500 text-white rounded-lg">导入</button>
    </div>
    
    <!-- Preview Table -->
    <div id="preview-section" class="hidden mt-4 border-t pt-4">
      <h4 class="font-medium mb-2">预览（共 <span id="preview-count">0</span> 条）</h4>
      <div class="max-h-64 overflow-y-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left py-2 px-2">课号</th>
              <th class="text-left py-2 px-2">名称</th>
              <th class="text-left py-2 px-2">教师</th>
              <th class="text-left py-2 px-2">班号</th>
              <th class="text-left py-2 px-2">学期</th>
              <th class="text-left py-2 px-2">校区</th>
            </tr>
          </thead>
          <tbody id="preview-body"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ API_BASE }}>
  const courseList = document.getElementById('course-list');
  const searchInput = document.getElementById('search-input');
  const courseModal = document.getElementById('course-modal');
  const courseForm = document.getElementById('course-form');
  const modalTitle = document.getElementById('modal-title');
  const addBtn = document.getElementById('add-course-btn');
  const cancelBtn = document.getElementById('cancel-btn');
  const exportBtn = document.getElementById('export-btn');
  
  // Bulk import elements
  const bulkModal = document.getElementById('bulk-modal');
  const bulkImportBtn = document.getElementById('bulk-import-btn');
  const bulkCancelBtn = document.getElementById('bulk-cancel-btn');
  const bulkPreviewBtn = document.getElementById('bulk-preview-btn');
  const bulkSubmitBtn = document.getElementById('bulk-submit-btn');
  const bulkDataInput = document.getElementById('bulk-data');
  const previewSection = document.getElementById('preview-section');
  const previewBody = document.getElementById('preview-body');
  const previewCount = document.getElementById('preview-count');
  const importResult = document.getElementById('import-result');
  
  let isEditing = false;
  let parsedCourses = [];
  
  // Export functionality
  exportBtn?.addEventListener('click', async () => {
    try {
      const res = await fetch(`${API_BASE}/api/admin/courses/export`, {
        credentials: 'include'
      });
      
      if (!res.ok) {
        throw new Error('导出失败');
      }
      
      const courses = await res.json();
      
      // Download as JSON file
      const blob = new Blob([JSON.stringify(courses, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `courses_export_${new Date().toISOString().split('T')[0]}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch (err) {
      alert('导出失败: ' + err.message);
    }
  });
  
  // Bulk import handlers
  bulkImportBtn?.addEventListener('click', () => {
    bulkDataInput.value = '';
    previewSection.classList.add('hidden');
    importResult.classList.add('hidden');
    parsedCourses = [];
    bulkModal.classList.remove('hidden');
    bulkModal.classList.add('flex');
  });
  
  bulkCancelBtn?.addEventListener('click', () => {
    bulkModal.classList.add('hidden');
    bulkModal.classList.remove('flex');
  });
  
  function parseCSV(text) {
    const lines = text.trim().split('\n').filter(line => line.trim());
    return lines.map(line => {
      const parts = line.split(',').map(p => p.trim());
      if (parts.length < 5) {
        throw new Error(`格式错误: "${line}" - 至少需要 5 个字段（课号,名称,简称,教师,学期）`);
      }
      return {
        code: parts[0],
        name: parts[1],
        name_abbr: parts[2] || null,
        teacher: parts[3],
        semester: parts[4],
        class_number: parts[5] || null,
        campus: parts[6] || null,
        time_location: parts[7] || null,
      };
    });
  }
  
  function parseJSON(text) {
    const data = JSON.parse(text);
    if (!Array.isArray(data)) {
      throw new Error('JSON 必须是数组格式');
    }
    return data.map((item, i) => {
      if (!item.code || !item.name || !item.teacher || !item.semester) {
        throw new Error(`第 ${i+1} 项缺少必要字段 (code, name, teacher, semester)`);
      }
      return {
        code: item.code,
        name: item.name,
        name_abbr: item.name_abbr || null,
        teacher: item.teacher,
        semester: item.semester,
        class_number: item.class_number || null,
        campus: item.campus || null,
        time_location: item.time_location || null,
      };
    });
  }
  
  bulkPreviewBtn?.addEventListener('click', () => {
    const format = document.querySelector('input[name="import-format"]:checked')?.value || 'csv';
    const text = bulkDataInput.value.trim();
    
    if (!text) {
      alert('请输入数据');
      return;
    }
    
    try {
      parsedCourses = format === 'csv' ? parseCSV(text) : parseJSON(text);
      
      previewCount.textContent = parsedCourses.length;
      previewBody.innerHTML = parsedCourses.map(c => `
        <tr class="border-b">
          <td class="py-1 px-2">${c.code}</td>
          <td class="py-1 px-2">${c.name}</td>
          <td class="py-1 px-2">${c.teacher}</td>
          <td class="py-1 px-2">${c.class_number || '-'}</td>
          <td class="py-1 px-2">${c.semester}</td>
          <td class="py-1 px-2">${c.campus || '-'}</td>
        </tr>
      `).join('');
      
      previewSection.classList.remove('hidden');
      importResult.classList.add('hidden');
    } catch (err) {
      alert('解析失败: ' + err.message);
    }
  });
  
  bulkSubmitBtn?.addEventListener('click', async () => {
    if (parsedCourses.length === 0) {
      alert('请先预览数据');
      return;
    }
    
    const skipDuplicates = document.getElementById('skip-duplicates').checked;
    
    bulkSubmitBtn.disabled = true;
    bulkSubmitBtn.textContent = '导入中...';
    
    try {
      const res = await fetch(`${API_BASE}/api/admin/courses/bulk-import`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          courses: parsedCourses,
          skip_duplicates: skipDuplicates,
        }),
      });
      
      const result = await res.json();
      
      if (!res.ok) {
        throw new Error(result.detail || '导入失败');
      }
      
      // Show result
      let resultClass = 'bg-green-50 text-green-800';
      if (result.errors.length > 0) {
        resultClass = 'bg-yellow-50 text-yellow-800';
      }
      
      importResult.className = `mb-4 p-4 rounded-lg ${resultClass}`;
      importResult.innerHTML = `
        <p class="font-medium">导入完成</p>
        <p>总计: ${result.total} 条 | 导入: ${result.imported} 条 | 跳过: ${result.skipped} 条</p>
        ${result.errors.length > 0 ? `
          <p class="mt-2 text-red-600">错误:</p>
          <ul class="list-disc list-inside text-sm">
            ${result.errors.map(e => `<li>${e}</li>`).join('')}
          </ul>
        ` : ''}
      `;
      importResult.classList.remove('hidden');
      
      if (result.imported > 0) {
        loadCourses();
      }
    } catch (err) {
      importResult.className = 'mb-4 p-4 rounded-lg bg-red-50 text-red-800';
      importResult.innerHTML = `<p>导入失败: ${err.message}</p>`;
      importResult.classList.remove('hidden');
    } finally {
      bulkSubmitBtn.disabled = false;
      bulkSubmitBtn.textContent = '导入';
    }
  });
  
  addBtn?.addEventListener('click', () => {
    isEditing = false;
    modalTitle.textContent = '添加课程';
    document.getElementById('course-id').value = '';
    document.getElementById('course-code').value = '';
    document.getElementById('course-name').value = '';
    document.getElementById('course-abbr').value = '';
    document.getElementById('course-teacher').value = '';
    document.getElementById('course-semester').value = '';
    document.getElementById('course-class-number').value = '';
    document.getElementById('course-campus').value = '';
    document.getElementById('course-time-location').value = '';
    courseModal.classList.remove('hidden');
    courseModal.classList.add('flex');
  });
  
  cancelBtn?.addEventListener('click', () => {
    courseModal.classList.add('hidden');
    courseModal.classList.remove('flex');
  });
  
  courseForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('course-id').value;
    const data = {
      code: document.getElementById('course-code').value,
      name: document.getElementById('course-name').value,
      name_abbr: document.getElementById('course-abbr').value || null,
      teacher: document.getElementById('course-teacher').value,
      semester: document.getElementById('course-semester').value,
      class_number: document.getElementById('course-class-number').value || null,
      campus: document.getElementById('course-campus').value || null,
      time_location: document.getElementById('course-time-location').value || null,
    };
    
    try {
      const url = isEditing ? `${API_BASE}/api/admin/courses/${id}` : `${API_BASE}/api/admin/courses`;
      const method = isEditing ? 'PUT' : 'POST';
      
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'include'
      });
      
      if (res.ok) {
        courseModal.classList.add('hidden');
        courseModal.classList.remove('flex');
        loadCourses();
      } else {
        const err = await res.json();
        alert(err.detail || '操作失败');
      }
    } catch (err) {
      alert('请求失败');
    }
  });
  
  let searchTimeout;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(loadCourses, 300);
  });
  
  window.openEdit = (course) => {
    isEditing = true;
    modalTitle.textContent = '编辑课程';
    document.getElementById('course-id').value = course.id;
    document.getElementById('course-code').value = course.code;
    document.getElementById('course-name').value = course.name;
    document.getElementById('course-abbr').value = course.name_abbr || '';
    document.getElementById('course-teacher').value = course.teacher;
    document.getElementById('course-semester').value = course.semester;
    document.getElementById('course-class-number').value = course.class_number || '';
    document.getElementById('course-campus').value = course.campus || '';
    document.getElementById('course-time-location').value = course.time_location || '';
    courseModal.classList.remove('hidden');
    courseModal.classList.add('flex');
  };
  
  window.deleteCourse = async (id) => {
    if (!confirm('确认删除此课程？如果课程下有任务，则无法删除。')) return;
    try {
      const res = await fetch(`${API_BASE}/api/admin/courses/${id}`, {
        method: 'DELETE',
        credentials: 'include'
      });
      if (res.ok) {
        loadCourses();
      } else {
        const err = await res.json();
        alert(err.detail || '删除失败');
      }
    } catch (err) {
      alert('请求失败');
    }
  };
  
  // Store courses for edit function - use window for global access
  window.allCourses = [];
  
  async function loadCourses() {
    const q = searchInput?.value || '';
    const params = new URLSearchParams({ page_size: '50' });
    if (q) params.set('q', q);
    
    try {
      const res = await fetch(`${API_BASE}/api/admin/courses?${params}`, {
        credentials: 'include'
      });
      
      if (!res.ok) {
        courseList.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-red-500">加载失败，请确认管理员登录</td></tr>';
        return;
      }
      
      const courses = await res.json();
      window.allCourses = courses;
      
      if (courses.length === 0) {
        courseList.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-gray-500">暂无课程</td></tr>';
        return;
      }
      
      courseList.innerHTML = courses.map((course, i) => `
        <tr class="border-b border-gray-50 hover:bg-gray-50">
          <td class="py-3 px-4 text-sm text-gray-600">${course.id}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.code}</td>
          <td class="py-3 px-4 text-sm text-gray-900">${course.name}${course.name_abbr ? ` (${course.name_abbr})` : ''}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.teacher}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.class_number || '-'}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.semester}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.campus || '-'}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.follower_count}</td>
          <td class="py-3 px-4 text-sm">
            <div class="flex gap-2">
              <button onclick="openEdit(window.allCourses[${i}])" class="text-blue-600 hover:text-blue-800">编辑</button>
              <button onclick="deleteCourse(${course.id})" class="text-red-600 hover:text-red-800">删除</button>
            </div>
          </td>
        </tr>
      `).join('');
    } catch (err) {
      console.error('Load courses error:', err);
      courseList.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-red-500">加载失败</td></tr>';
    }
  }
  
  loadCourses();
</script>
