---
import AdminLayout from '../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<AdminLayout title="课程管理" currentPage="/courses">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">课程管理</h2>
      <p class="text-gray-500 mt-1">管理课程底库</p>
    </div>
    <div class="flex gap-2">
      <input 
        type="text" 
        id="search-input"
        placeholder="搜索课程..." 
        class="px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <button id="add-course-btn" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
        添加课程
      </button>
    </div>
  </div>
  
  <!-- Course Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">课号</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">名称</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">教师</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">学期</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">关注数</th>
        </tr>
      </thead>
      <tbody id="course-list">
        <tr>
          <td colspan="5" class="text-center py-8 text-gray-500">加载中...</td>
        </tr>
      </tbody>
    </table>
  </div>
</AdminLayout>

<!-- Add Course Modal -->
<div id="add-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
  <div class="bg-white rounded-xl p-6 w-full max-w-md">
    <h3 class="text-lg font-semibold mb-4">添加课程</h3>
    <form id="add-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">课程号</label>
        <input type="text" name="course_code" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: CS101" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">课程名称</label>
        <input type="text" name="name" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 数据结构" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">简称（可选）</label>
        <input type="text" name="name_abbr" class="w-full px-3 py-2 border rounded-lg" placeholder="如: DS" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">授课教师</label>
        <input type="text" name="teacher" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 张三" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">学期</label>
        <input type="text" name="semester" required class="w-full px-3 py-2 border rounded-lg" placeholder="如: 2026-Spring" />
      </div>
      <div class="flex gap-2 justify-end">
        <button type="button" id="cancel-btn" class="px-4 py-2 bg-gray-100 rounded-lg">取消</button>
        <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg">添加</button>
      </div>
    </form>
  </div>
</div>

<script define:vars={{ API_BASE }}>
  const courseList = document.getElementById('course-list');
  const searchInput = document.getElementById('search-input');
  const addModal = document.getElementById('add-modal');
  const addForm = document.getElementById('add-form');
  const addBtn = document.getElementById('add-course-btn');
  const cancelBtn = document.getElementById('cancel-btn');
  
  addBtn?.addEventListener('click', () => {
    addModal.classList.remove('hidden');
    addModal.classList.add('flex');
  });
  
  cancelBtn?.addEventListener('click', () => {
    addModal.classList.add('hidden');
    addModal.classList.remove('flex');
  });
  
  addForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(addForm);
    const data = Object.fromEntries(formData.entries());
    
    try {
      const res = await fetch(`${API_BASE}/api/courses`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'include'
      });
      
      if (res.ok) {
        addModal.classList.add('hidden');
        addForm.reset();
        loadCourses();
      } else {
        const err = await res.json();
        alert(err.detail || '添加失败');
      }
    } catch (err) {
      alert('请求失败');
    }
  });
  
  let searchTimeout;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(loadCourses, 300);
  });
  
  async function loadCourses() {
    const q = searchInput?.value || '';
    const params = new URLSearchParams({ page_size: '50' });
    if (q) params.set('q', q);
    
    try {
      const res = await fetch(`${API_BASE}/api/courses?${params}`, {
        credentials: 'include'
      });
      
      if (!res.ok) {
        courseList.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-red-500">加载失败</td></tr>';
        return;
      }
      
      const courses = await res.json();
      
      if (courses.length === 0) {
        courseList.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-gray-500">暂无课程</td></tr>';
        return;
      }
      
      courseList.innerHTML = courses.map(course => `
        <tr class="border-b border-gray-50 hover:bg-gray-50">
          <td class="py-3 px-4 text-sm text-gray-600">${course.course_code}</td>
          <td class="py-3 px-4 text-sm text-gray-900">${course.name}${course.name_abbr ? ` (${course.name_abbr})` : ''}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.teacher}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.semester}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${course.followers_count}</td>
        </tr>
      `).join('');
    } catch (err) {
      console.error('Load courses error:', err);
      courseList.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-red-500">加载失败</td></tr>';
    }
  }
  
  loadCourses();
</script>
