---
import AdminLayout from '../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<AdminLayout title="修改建议审核" currentPage="/proposals">
  <div class="mb-6">
    <div class="flex justify-between items-center mb-4">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">修改建议审核</h2>
        <p class="text-gray-500 mt-1">审核用户提交的 DDL 说明修改建议</p>
      </div>
      <div class="flex gap-2">
        <button id="tab-pending" class="px-4 py-2 bg-yellow-500 text-white rounded-lg">待审核</button>
        <button id="tab-approved" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg">已通过</button>
        <button id="tab-rejected" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg">已拒绝</button>
      </div>
    </div>
    
    <!-- Batch Actions -->
    <div id="batch-actions" class="hidden bg-blue-50 rounded-xl p-4 mb-4 flex items-center justify-between">
      <span class="text-blue-700">已选择 <span id="selected-count">0</span> 项</span>
      <div class="flex gap-2">
        <button id="batch-approve" class="px-3 py-1.5 bg-green-500 text-white rounded-lg text-sm hover:bg-green-600">批量通过</button>
        <button id="batch-reject" class="px-3 py-1.5 bg-red-500 text-white rounded-lg text-sm hover:bg-red-600">批量拒绝</button>
        <button id="cancel-selection" class="px-3 py-1.5 bg-gray-200 text-gray-700 rounded-lg text-sm hover:bg-gray-300">取消</button>
      </div>
    </div>
  </div>
  
  <!-- Proposals Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="py-3 px-4 text-left">
            <input type="checkbox" id="select-all" class="rounded" />
          </th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">ID</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">任务</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">建议内容</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">提交者</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">评分</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">状态</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">操作</th>
        </tr>
      </thead>
      <tbody id="proposals-list">
        <tr>
          <td colspan="8" class="text-center py-8 text-gray-500">加载中...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <!-- Detail Modal -->
  <div id="detail-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-semibold mb-4">修改建议详情</h3>
      <div id="detail-content" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">任务信息</label>
          <div id="detail-task" class="p-3 bg-gray-50 rounded-lg"></div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">当前说明</label>
          <div id="detail-current" class="p-3 bg-gray-50 rounded-lg whitespace-pre-wrap"></div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">建议修改为</label>
          <div id="detail-new" class="p-3 bg-blue-50 rounded-lg whitespace-pre-wrap border-2 border-blue-200"></div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">修改原因</label>
          <div id="detail-reason" class="p-3 bg-gray-50 rounded-lg"></div>
        </div>
        <div class="flex gap-4 text-sm text-gray-500">
          <span>提交者: <span id="detail-proposer"></span></span>
          <span>赞同: <span id="detail-upvotes" class="text-green-600"></span></span>
          <span>反对: <span id="detail-downvotes" class="text-red-600"></span></span>
        </div>
      </div>
      <div class="flex justify-end gap-2 pt-6 border-t mt-4">
        <button type="button" onclick="closeDetailModal()" class="px-4 py-2 border rounded-lg">关闭</button>
        <button type="button" id="btn-reject" onclick="rejectProposal()" class="px-4 py-2 bg-red-500 text-white rounded-lg">拒绝</button>
        <button type="button" id="btn-approve" onclick="approveProposal()" class="px-4 py-2 bg-green-500 text-white rounded-lg">通过</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ API_BASE }}>
  let currentTab = 'pending';
  let currentProposalId = null;
  let currentTaskId = null;
  let allProposals = [];
  window.selectedIds = new Set();
  
  const tabPending = document.getElementById('tab-pending');
  const tabApproved = document.getElementById('tab-approved');
  const tabRejected = document.getElementById('tab-rejected');
  const proposalsList = document.getElementById('proposals-list');
  const detailModal = document.getElementById('detail-modal');
  const selectAllCheckbox = document.getElementById('select-all');
  const batchActions = document.getElementById('batch-actions');
  const selectedCountSpan = document.getElementById('selected-count');
  
  function updateSelection() {
    const count = window.selectedIds.size;
    selectedCountSpan.textContent = count;
    if (count > 0) {
      batchActions.classList.remove('hidden');
    } else {
      batchActions.classList.add('hidden');
    }
    
    const checkboxes = document.querySelectorAll('.proposal-checkbox');
    const allChecked = checkboxes.length > 0 && [...checkboxes].every(cb => cb.checked);
    selectAllCheckbox.checked = allChecked;
  }
  
  selectAllCheckbox?.addEventListener('change', (e) => {
    const checkboxes = document.querySelectorAll('.proposal-checkbox');
    checkboxes.forEach(cb => {
      cb.checked = e.target.checked;
      const id = parseInt(cb.dataset.id);
      if (e.target.checked) {
        window.selectedIds.add(id);
      } else {
        window.selectedIds.delete(id);
      }
    });
    updateSelection();
  });
  
  document.getElementById('cancel-selection')?.addEventListener('click', () => {
    window.selectedIds.clear();
    document.querySelectorAll('.proposal-checkbox').forEach(cb => cb.checked = false);
    selectAllCheckbox.checked = false;
    updateSelection();
  });
  
  window.toggleSelect = (id, checked) => {
    if (checked) {
      window.selectedIds.add(id);
    } else {
      window.selectedIds.delete(id);
    }
    updateSelection();
  };
  
  // Batch operations
  document.getElementById('batch-approve')?.addEventListener('click', async () => {
    const ids = [...window.selectedIds];
    if (ids.length === 0) return;
    if (!confirm(`确认批量通过 ${ids.length} 个修改建议？`)) return;
    
    let successCount = 0;
    for (const id of ids) {
      try {
        const res = await fetch(`${API_BASE}/api/admin/proposals/${id}/approve`, { 
          method: 'POST', 
          credentials: 'include' 
        });
        if (res.ok) successCount++;
      } catch (e) {
        console.error('Approve error:', e);
      }
    }
    
    alert(`批量通过完成：成功 ${successCount} 条，失败 ${ids.length - successCount} 条`);
    window.selectedIds.clear();
    updateSelection();
    loadProposals();
  });
  
  document.getElementById('batch-reject')?.addEventListener('click', async () => {
    const ids = [...window.selectedIds];
    if (ids.length === 0) return;
    if (!confirm(`确认批量拒绝 ${ids.length} 个修改建议？`)) return;
    
    let successCount = 0;
    for (const id of ids) {
      try {
        const res = await fetch(`${API_BASE}/api/admin/proposals/${id}/reject`, { 
          method: 'POST', 
          credentials: 'include' 
        });
        if (res.ok) successCount++;
      } catch (e) {
        console.error('Reject error:', e);
      }
    }
    
    alert(`批量拒绝完成：成功 ${successCount} 条，失败 ${ids.length - successCount} 条`);
    window.selectedIds.clear();
    updateSelection();
    loadProposals();
  });
  
  function setActiveTab(tab) {
    console.log('setActiveTab called with:', tab);
    currentTab = tab;
    
    if (tabPending) {
      tabPending.className = tab === 'pending' 
        ? 'px-4 py-2 bg-yellow-500 text-white rounded-lg' 
        : 'px-4 py-2 bg-gray-100 text-gray-700 rounded-lg';
    }
    if (tabApproved) {
      tabApproved.className = tab === 'approved' 
        ? 'px-4 py-2 bg-green-500 text-white rounded-lg' 
        : 'px-4 py-2 bg-gray-100 text-gray-700 rounded-lg';
    }
    if (tabRejected) {
      tabRejected.className = tab === 'rejected' 
        ? 'px-4 py-2 bg-red-500 text-white rounded-lg' 
        : 'px-4 py-2 bg-gray-100 text-gray-700 rounded-lg';
    }
    
    // Clear selection when switching tabs
    window.selectedIds.clear();
    updateSelection();
    
    loadProposals();
  }
  
  console.log('Tab elements:', { tabPending, tabApproved, tabRejected });
  
  if (tabPending) {
    tabPending.addEventListener('click', () => {
      console.log('Pending tab clicked');
      setActiveTab('pending');
    });
  }
  if (tabApproved) {
    tabApproved.addEventListener('click', () => {
      console.log('Approved tab clicked');
      setActiveTab('approved');
    });
  }
  if (tabRejected) {
    tabRejected.addEventListener('click', () => {
      console.log('Rejected tab clicked');
      setActiveTab('rejected');
    });
  }
  
  async function loadProposals() {
    console.log('loadProposals called, currentTab:', currentTab);
    try {
      const url = `${API_BASE}/api/admin/proposals?status=${currentTab}`;
      console.log('Fetching:', url);
      const res = await fetch(url, { 
        credentials: 'include' 
      });
      console.log('Response status:', res.status);
      
      if (!res.ok) {
        const errText = await res.text();
        console.error('Load proposals failed:', errText);
        proposalsList.innerHTML = '<tr><td colspan="8" class="text-center py-8 text-red-500">加载失败，请确认管理员登录</td></tr>';
        return;
      }
      
      const proposals = await res.json();
      console.log('Proposals loaded:', proposals.length);
      allProposals = proposals;
      
      if (proposals.length === 0) {
        proposalsList.innerHTML = '<tr><td colspan="8" class="text-center py-8 text-gray-500">暂无数据</td></tr>';
        return;
      }
      
      proposalsList.innerHTML = proposals.map(p => `
        <tr class="border-b border-gray-50 hover:bg-gray-50">
          <td class="py-3 px-4">
            <input type="checkbox" class="proposal-checkbox rounded" data-id="${p.id}" 
              ${window.selectedIds.has(p.id) ? 'checked' : ''} 
              onchange="toggleSelect(${p.id}, this.checked)" />
          </td>
          <td class="py-3 px-4 text-sm text-gray-600">${p.id}</td>
          <td class="py-3 px-4 text-sm text-gray-900">
            <div class="max-w-xs">
              <div class="font-medium">任务 #${p.task_id}</div>
              <div class="text-gray-600 truncate">${p.task_title || '未知'}</div>
            </div>
          </td>
          <td class="py-3 px-4 text-sm text-gray-900 max-w-md">
            <div class="line-clamp-2">${p.new_description}</div>
          </td>
          <td class="py-3 px-4 text-sm text-gray-600">${p.proposer_nickname || '匿名'}</td>
          <td class="py-3 px-4 text-sm">
            <span class="text-green-600">+${p.upvotes}</span> / 
            <span class="text-red-600">-${p.downvotes}</span>
          </td>
          <td class="py-3 px-4 text-sm">
            <span class="px-2 py-1 rounded text-xs ${
              p.status === 'approved' ? 'bg-green-100 text-green-700' :
              p.status === 'rejected' ? 'bg-red-100 text-red-700' :
              'bg-yellow-100 text-yellow-700'
            }">${p.status === 'approved' ? '已通过' : p.status === 'rejected' ? '已拒绝' : '待审核'}</span>
          </td>
          <td class="py-3 px-4 text-sm">
            <div class="flex gap-2">
              <button onclick="viewProposal(${p.id}, ${p.task_id})" class="text-blue-600 hover:text-blue-800">查看</button>
              ${p.status === 'pending' ? `
                <button onclick="quickApprove(${p.id})" class="text-green-600 hover:text-green-800">通过</button>
                <button onclick="quickReject(${p.id})" class="text-red-600 hover:text-red-800">拒绝</button>
              ` : ''}
            </div>
          </td>
        </tr>
      `).join('');
    } catch (err) {
      console.error('Load proposals error:', err);
      proposalsList.innerHTML = '<tr><td colspan="8" class="text-center py-8 text-red-500">加载失败</td></tr>';
    }
  }
  
  window.viewProposal = async (proposalId, taskId) => {
    currentProposalId = proposalId;
    currentTaskId = taskId;
    
    try {
      // Load task and proposal details
      const [taskRes, proposalRes] = await Promise.all([
        fetch(`${API_BASE}/api/admin/tasks/${taskId}`, { credentials: 'include' }),
        fetch(`${API_BASE}/api/admin/proposals/${proposalId}`, { credentials: 'include' })
      ]);
      
      if (!taskRes.ok || !proposalRes.ok) {
        alert('获取详情失败');
        return;
      }
      
      const task = await taskRes.json();
      const proposal = await proposalRes.json();
      
      document.getElementById('detail-task').textContent = `${task.course_name} - ${task.title}`;
      document.getElementById('detail-current').textContent = task.description || '(无说明)';
      document.getElementById('detail-new').textContent = proposal.new_description;
      document.getElementById('detail-reason').textContent = proposal.reason || '(未说明)';
      document.getElementById('detail-proposer').textContent = proposal.proposer_nickname || '匿名';
      document.getElementById('detail-upvotes').textContent = proposal.upvotes;
      document.getElementById('detail-downvotes').textContent = proposal.downvotes;
      
      // Show/hide action buttons based on status
      const isPending = proposal.status === 'pending';
      document.getElementById('btn-approve').style.display = isPending ? 'block' : 'none';
      document.getElementById('btn-reject').style.display = isPending ? 'block' : 'none';
      
      detailModal.classList.remove('hidden');
      detailModal.classList.add('flex');
    } catch (err) {
      console.error('Load proposal error:', err);
      alert('获取详情失败');
    }
  };
  
  window.closeDetailModal = () => {
    detailModal.classList.add('hidden');
    detailModal.classList.remove('flex');
    currentProposalId = null;
    currentTaskId = null;
  };
  
  window.approveProposal = async () => {
    if (!currentProposalId || !confirm('确认通过此修改建议？')) return;
    
    try {
      const res = await fetch(`${API_BASE}/api/admin/proposals/${currentProposalId}/approve`, {
        method: 'POST',
        credentials: 'include'
      });
      
      if (!res.ok) {
        const err = await res.json();
        alert(err.detail || '操作失败');
        return;
      }
      
      closeDetailModal();
      loadProposals();
    } catch (err) {
      console.error('Approve error:', err);
      alert('操作失败');
    }
  };
  
  window.rejectProposal = async () => {
    if (!currentProposalId || !confirm('确认拒绝此修改建议？')) return;
    
    try {
      const res = await fetch(`${API_BASE}/api/admin/proposals/${currentProposalId}/reject`, {
        method: 'POST',
        credentials: 'include'
      });
      
      if (!res.ok) {
        const err = await res.json();
        alert(err.detail || '操作失败');
        return;
      }
      
      closeDetailModal();
      loadProposals();
    } catch (err) {
      console.error('Reject error:', err);
      alert('操作失败');
    }
  };
  
  window.quickApprove = async (id) => {
    if (!confirm('确认通过此修改建议？')) return;
    await fetch(`${API_BASE}/api/admin/proposals/${id}/approve`, { method: 'POST', credentials: 'include' });
    loadProposals();
  };
  
  window.quickReject = async (id) => {
    if (!confirm('确认拒绝此修改建议？')) return;
    await fetch(`${API_BASE}/api/admin/proposals/${id}/reject`, { method: 'POST', credentials: 'include' });
    loadProposals();
  };
  
  loadProposals();
</script>
