---
import AdminLayout from '../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<AdminLayout title="任务管理" currentPage="/tasks">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">任务管理</h2>
      <p class="text-gray-500 mt-1">查看和管理所有 DDL 任务</p>
    </div>
    <div class="flex gap-2">
      <input type="text" id="search" placeholder="搜索标题..." class="px-4 py-2 border rounded-lg" />
      <select id="status-filter" class="px-4 py-2 border rounded-lg">
        <option value="">全部状态</option>
        <option value="pending">待验证</option>
        <option value="verified">已验证</option>
        <option value="hidden">已隐藏</option>
      </select>
      <button id="tab-all" class="px-4 py-2 bg-blue-500 text-white rounded-lg">全部</button>
      <button id="tab-reported" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg">被举报</button>
    </div>
  </div>
  
  <!-- Task Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">ID</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">课程</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">标题</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">截止时间</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">评分</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">状态</th>
          <th class="text-left py-3 px-4 text-sm font-medium text-gray-500">操作</th>
        </tr>
      </thead>
      <tbody id="task-list">
        <tr>
          <td colspan="7" class="text-center py-8 text-gray-500">加载中...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <!-- Edit Modal -->
  <div id="edit-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-lg mx-4">
      <h3 class="text-lg font-semibold mb-4">编辑任务</h3>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" id="edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">标题</label>
          <input type="text" id="edit-title" class="w-full px-3 py-2 border rounded-lg" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">截止时间</label>
          <input type="datetime-local" id="edit-due-time" class="w-full px-3 py-2 border rounded-lg" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">状态</label>
          <select id="edit-status" class="w-full px-3 py-2 border rounded-lg">
            <option value="pending">待验证</option>
            <option value="verified">已验证</option>
            <option value="hidden">已隐藏</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">详细说明</label>
          <textarea id="edit-description" class="w-full px-3 py-2 border rounded-lg" rows="3"></textarea>
        </div>
        <div class="flex justify-end gap-2 pt-4">
          <button type="button" onclick="closeEditModal()" class="px-4 py-2 border rounded-lg">取消</button>
          <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg">保存</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ API_BASE }}>
  let currentTab = 'all';
  
  const tabAll = document.getElementById('tab-all');
  const tabReported = document.getElementById('tab-reported');
  const taskList = document.getElementById('task-list');
  const searchInput = document.getElementById('search');
  const statusFilter = document.getElementById('status-filter');
  const editModal = document.getElementById('edit-modal');
  const editForm = document.getElementById('edit-form');
  
  tabAll?.addEventListener('click', () => {
    currentTab = 'all';
    tabAll.className = 'px-4 py-2 bg-blue-500 text-white rounded-lg';
    tabReported.className = 'px-4 py-2 bg-gray-100 text-gray-700 rounded-lg';
    loadTasks();
  });
  
  tabReported?.addEventListener('click', () => {
    currentTab = 'reported';
    tabReported.className = 'px-4 py-2 bg-red-500 text-white rounded-lg';
    tabAll.className = 'px-4 py-2 bg-gray-100 text-gray-700 rounded-lg';
    loadTasks();
  });
  
  searchInput?.addEventListener('input', debounce(loadTasks, 300));
  statusFilter?.addEventListener('change', loadTasks);
  
  function debounce(fn, ms) {
    let timeout;
    return () => { clearTimeout(timeout); timeout = setTimeout(fn, ms); };
  }
  
  async function loadTasks() {
    const q = searchInput?.value || '';
    const status = statusFilter?.value || '';
    
    let endpoint = currentTab === 'reported' 
      ? '/api/admin/tasks/reported'
      : `/api/admin/tasks?q=${encodeURIComponent(q)}${status ? `&status=${status}` : ''}`;
    
    try {
      const res = await fetch(`${API_BASE}${endpoint}`, { credentials: 'include' });
      
      if (!res.ok) {
        taskList.innerHTML = '<tr><td colspan="7" class="text-center py-8 text-red-500">加载失败，请确认管理员登录</td></tr>';
        return;
      }
      
      const tasks = await res.json();
      
      if (tasks.length === 0) {
        taskList.innerHTML = '<tr><td colspan="7" class="text-center py-8 text-gray-500">暂无数据</td></tr>';
        return;
      }
      
      taskList.innerHTML = tasks.map(task => `
        <tr class="border-b border-gray-50 hover:bg-gray-50">
          <td class="py-3 px-4 text-sm text-gray-600">${task.id}</td>
          <td class="py-3 px-4 text-sm text-gray-900">${task.course_name}</td>
          <td class="py-3 px-4 text-sm text-gray-900 max-w-xs truncate">${task.title}</td>
          <td class="py-3 px-4 text-sm text-gray-600">${task.due_time ? new Date(task.due_time).toLocaleString('zh-CN') : '-'}</td>
          <td class="py-3 px-4 text-sm">
            <span class="text-green-600">+${task.upvotes}</span> / 
            <span class="text-red-600">-${task.downvotes}</span>
          </td>
          <td class="py-3 px-4 text-sm">
            <span class="px-2 py-1 rounded text-xs ${
              task.status === 'verified' ? 'bg-green-100 text-green-700' :
              task.status === 'hidden' ? 'bg-gray-100 text-gray-700' :
              'bg-yellow-100 text-yellow-700'
            }">${task.status === 'verified' ? '已验证' : task.status === 'hidden' ? '已隐藏' : '待验证'}</span>
            ${task.is_reported ? '<span class="ml-1 px-2 py-1 bg-red-100 text-red-700 rounded text-xs">举报</span>' : ''}
          </td>
          <td class="py-3 px-4 text-sm">
            <div class="flex gap-2">
              <button onclick="openEditTask(${task.id})" class="text-blue-600 hover:text-blue-800">编辑</button>
              <button onclick="verifyTask(${task.id})" class="text-green-600 hover:text-green-800">验证</button>
              <button onclick="hideTask(${task.id})" class="text-yellow-600 hover:text-yellow-800">隐藏</button>
              <button onclick="deleteTask(${task.id})" class="text-red-600 hover:text-red-800">删除</button>
            </div>
          </td>
        </tr>
      `).join('');
    } catch (err) {
      console.error('Load tasks error:', err);
      taskList.innerHTML = '<tr><td colspan="7" class="text-center py-8 text-red-500">加载失败</td></tr>';
    }
  }
  
  window.openEditTask = async (id) => {
    try {
      const res = await fetch(`${API_BASE}/api/admin/tasks/${id}`, { credentials: 'include' });
      if (!res.ok) {
        alert('获取任务详情失败');
        return;
      }
      const task = await res.json();
      
      document.getElementById('edit-id').value = task.id;
      document.getElementById('edit-title').value = task.title;
      document.getElementById('edit-description').value = task.description || '';
      document.getElementById('edit-status').value = task.status;
      
      // Format datetime for input
      const dueTime = new Date(task.due_time);
      const localDateTime = new Date(dueTime.getTime() - dueTime.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
      document.getElementById('edit-due-time').value = localDateTime;
      
      editModal.classList.remove('hidden');
      editModal.classList.add('flex');
    } catch (err) {
      console.error('Load task error:', err);
      alert('获取任务详情失败');
    }
  };
  
  window.closeEditModal = () => {
    editModal.classList.add('hidden');
    editModal.classList.remove('flex');
  };
  
  editForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('edit-id').value;
    // Send datetime without timezone conversion - keep as local time
    const dueTimeValue = document.getElementById('edit-due-time').value;
    const data = {
      title: document.getElementById('edit-title').value,
      description: document.getElementById('edit-description').value || null,
      due_time: dueTimeValue ? dueTimeValue + ':00' : null,  // Format: 2026-03-30T23:59:00
      status: document.getElementById('edit-status').value,
    };
    
    try {
      const res = await fetch(`${API_BASE}/api/admin/tasks/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data),
      });
      
      if (!res.ok) {
        const err = await res.json();
        alert(err.detail || '更新失败');
        return;
      }
      
      closeEditModal();
      loadTasks();
    } catch (err) {
      console.error('Update task error:', err);
      alert('更新失败');
    }
  });
  
  window.verifyTask = async (id) => {
    if (!confirm('确认验证此任务？')) return;
    await fetch(`${API_BASE}/api/admin/tasks/${id}/verify`, { method: 'POST', credentials: 'include' });
    loadTasks();
  };
  
  window.hideTask = async (id) => {
    if (!confirm('确认隐藏此任务？')) return;
    await fetch(`${API_BASE}/api/admin/tasks/${id}/hide`, { method: 'POST', credentials: 'include' });
    loadTasks();
  };
  
  window.deleteTask = async (id) => {
    if (!confirm('确认删除此任务？此操作不可恢复！')) return;
    await fetch(`${API_BASE}/api/admin/tasks/${id}`, { method: 'DELETE', credentials: 'include' });
    loadTasks();
  };
  
  loadTasks();
</script>
